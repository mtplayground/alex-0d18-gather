# Server
HOST=0.0.0.0
PORT=8080
SELF_URL=https://your-app.mctai.app
ALLOWED_CORS_ORIGIN=https://your-app.mctai.app
# Optional for self-hosted runs. Packaged run.sh defaults this to ./frontend.
FRONTEND_DIST_DIR=dist/self-hosted/frontend

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_MAX_CONNECTIONS=5
DATABASE_ACQUIRE_TIMEOUT_SECONDS=10
# Optional. Leave unset to use the mode from DATABASE_URL.
# DATABASE_SSL_MODE=require

# Object storage: use these exact names.
OBJECT_STORAGE_ACCESS_KEY_ID=replace-me
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-me
OBJECT_STORAGE_BUCKET=replace-me
OBJECT_STORAGE_PREFIX=app_alex_0d18_gather_aeccca/
OBJECT_STORAGE_ENDPOINT=https://example.storage.dev
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# myClawTeam auth service
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=replace-me
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# myClawTeam email proxy. Optional until email flows are implemented.
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=replace-me

# Legacy compatibility only. New code should read mctai_session instead of
# issuing app JWTs.
JWT_SECRET=replace-me
